---
const links = [
  { href: '#about',     label: 'About'     },
  { href: '#skills',    label: 'Skills'    },
  { href: '#projects',  label: 'Projects'  },
  { href: '#education', label: 'Education' },
  { href: '#contact',   label: 'Contact'   },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="text-2xl font-bold gradient-text tracking-tight">AH.</a>

    <!-- Desktop links -->
    <ul class="hidden md:flex gap-8">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-slate-400 hover:text-white transition-colors duration-200 tracking-wide"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href="mailto:akshay.a.hegde@accenture.com"
      class="hidden md:inline-flex items-center gap-2 px-5 py-2 rounded-full border border-purple-500/40 text-purple-300 hover:bg-purple-500/10 text-sm font-medium transition-all duration-200"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
      Get in touch
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-toggle" class="md:hidden text-slate-400 hover:text-white" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[#060a14]/95 backdrop-blur-md border-t border-slate-800 px-6 py-4">
    {links.map(link => (
      <a href={link.href} class="block py-2 text-slate-400 hover:text-white text-sm transition-colors mobile-link">
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const toggle = document.getElementById('mobile-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;

  // Scroll: add backdrop
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-[#060a14]/80', 'backdrop-blur-md', 'border-b', 'border-slate-800/60');
    } else {
      navbar.classList.remove('bg-[#060a14]/80', 'backdrop-blur-md', 'border-b', 'border-slate-800/60');
    }
  });

  // Mobile toggle
  toggle.addEventListener('click', () => menu.classList.toggle('hidden'));
  document.querySelectorAll('.mobile-link').forEach(link =>
    link.addEventListener('click', () => menu.classList.add('hidden'))
  );
</script>

