---
const projects = [
  {
    title: 'LLM Document Intelligence API',
    description:
      'Built an API endpoint that lets users attach files (docs & images) for outline generation and document scoring. Uses Azure Blob Storage, Azure AI Search, and embedding-based RAG with async fallback retrieval when info is absent in the attachment.',
    tags: ['Python', 'Azure Blob Storage', 'Azure AI Search', 'RAG', 'LangChain'],
    emoji: '📄',
    accent: 'from-purple-600 to-violet-600',
    github: 'https://github.com/Akshess',
    demo: '#',
  },
  {
    title: 'RAG-Based Resume Analyzer',
    description:
      'End-to-end RAG pipeline integrating ChromaDB vector store with HuggingFace transformer models for semantic matching between resumes and job descriptions. Implemented document chunking and embedding strategies using LangChain for context-aware feedback generation.',
    tags: ['Streamlit', 'FastAPI', 'ChromaDB', 'HuggingFace', 'LangChain'],
    emoji: '🔍',
    accent: 'from-cyan-600 to-blue-600',
    github: 'https://github.com/Akshess',
    demo: '#',
  },
  {
    title: 'PowerPoint Automation Pipeline',
    description:
      'Python pipeline to extract icons and images from PowerPoint files, convert them to required formats, and generate structured metadata and descriptions via GPT models through LangChain — automating 70% of manual documentation effort.',
    tags: ['Python', 'LangChain', 'GPT', 'Azure Cognitive Services', 'Automation'],
    emoji: '⚡',
    accent: 'from-pink-600 to-rose-600',
    github: 'https://github.com/Akshess',
    demo: '#',
  },
  {
    title: 'SharePoint → Azure Search Pipeline',
    description:
      'Automated data pipeline integrating SharePoint documents into Azure Blob Storage and indexed via Azure AI Search with bi-daily refresh cycles — improving document retrieval speed by 50% and factual accuracy of LLM responses by 45%.',
    tags: ['Python', 'SharePoint', 'Azure Blob', 'Azure AI Search', 'Azure Cosmos DB'],
    emoji: '🔄',
    accent: 'from-amber-600 to-orange-600',
    github: 'https://github.com/Akshess',
    demo: '#',
  },
];
---

<section id="projects" class="py-28 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-16 reveal">
      <p class="text-sm font-semibold text-purple-400 tracking-widest uppercase mb-3">What I've built</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white">
        Featured <span class="gradient-text">Projects</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project, i) => (
        <article
          class="gradient-border-card rounded-2xl p-7 flex flex-col gap-5 group hover:shadow-xl hover:shadow-purple-900/20 transition-all duration-300 reveal"
          style={`transition-delay: ${i * 0.1}s`}
        >
          <!-- Header -->
          <div class="flex items-start justify-between gap-4">
            <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${project.accent} flex items-center justify-center text-2xl flex-shrink-0 group-hover:scale-110 transition-transform duration-300`}>
              {project.emoji}
            </div>
            <div class="flex gap-3">
              <a href={project.github} class="text-slate-500 hover:text-white transition-colors" aria-label="GitHub">
                <!-- GitHub icon -->
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.74-1.33-1.74-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.82.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
              <a href={project.demo} class="text-slate-500 hover:text-white transition-colors" aria-label="Live demo">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Content -->
          <div>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:gradient-text transition-all">{project.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{project.description}</p>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mt-auto">
            {project.tags.map(tag => (
              <span class="px-2.5 py-1 rounded-md bg-slate-800/60 text-slate-400 text-xs border border-slate-700/50">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

