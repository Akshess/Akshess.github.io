---
const socials = [
  {
    label: 'Email',
    value: 'akshesshegde@gmail.com',
    href: 'mailto:akshesshegde@gmail.com',
    emoji: '✉️',
    color: 'hover:border-purple-500/50 hover:bg-purple-500/5',
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/akshay-hegde-3b2b36202',
    href: 'https://linkedin.com/in/akshay-hegde-3b2b36202',
    emoji: '💼',
    color: 'hover:border-blue-500/50 hover:bg-blue-500/5',
  },
  {
    label: 'GitHub',
    value: 'github.com/Akshess',
    href: 'https://github.com/Akshess',
    emoji: '💻',
    color: 'hover:border-slate-400/50 hover:bg-slate-500/5',
  },
];
---

<section id="contact" class="py-28 px-6">
  <div class="max-w-3xl mx-auto text-center">

    <!-- Heading -->
    <div class="reveal mb-12">
      <p class="text-sm font-semibold text-purple-400 tracking-widest uppercase mb-3">Let's talk</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-5">
        Get in <span class="gradient-text">touch</span>
      </h2>
      <p class="text-slate-400 text-base leading-relaxed max-w-lg mx-auto">
        Whether it's a collaboration, a project idea, or just a conversation about AI —
        I'm always happy to connect.
      </p>
    </div>

    <!-- Contact cards -->
    <div class="flex flex-col gap-4 reveal" style="transition-delay: 0.15s">
      {socials.map(s => (
        <a
          href={s.href}
          target={s.href.startsWith('mailto') ? undefined : '_blank'}
          rel="noopener noreferrer"
          class={`gradient-border-card rounded-2xl p-5 flex items-center gap-5 text-left transition-all duration-200 group ${s.color}`}
        >
          <span class="text-3xl w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800/60 flex-shrink-0">
            {s.emoji}
          </span>
          <div class="min-w-0">
            <p class="text-xs text-slate-500 uppercase tracking-widest">{s.label}</p>
            <p class="text-white text-sm font-medium truncate mt-0.5 group-hover:text-purple-300 transition-colors">
              {s.value}
            </p>
          </div>
          <svg class="w-4 h-4 text-slate-600 group-hover:text-white ml-auto flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>

    <!-- Divider + footer note -->
    <div class="mt-16 pt-8 border-t border-slate-800/60 reveal" style="transition-delay: 0.3s">
      <p class="text-slate-600 text-sm">
        Built with <span class="text-purple-400">Astro</span> + <span class="text-cyan-400">Tailwind CSS</span>
        &nbsp;·&nbsp; © {new Date().getFullYear()} Akshay Hegde
      </p>
    </div>

  </div>
</section>

